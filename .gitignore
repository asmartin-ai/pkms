# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
**/.venv*/
venv/
*.egg-info/
dist/
build/

# Database (index is regenerated from vault)
*.db
*.db-shm
*.db-wal
.index/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/settings.json
*.swp
*~

# Secrets
.env
*.env.local
.secrets/

# Claude Code machine-local permissions (skills/ stays tracked)
.claude/settings.local.json

# Impeccable live-mode runtime recovery state
.impeccable/live/sessions/

# Throwaway experiments and generated exports are local-only
spike/
exports/

# Archives and bundled vault duplicates must not be added accidentally
vault/**/*.zip
vault/**/*.tar
vault/**/*.tar.gz
vault/**/*.7z

# Personal vault content — kept local, not published (app recreates dirs on demand)
vault/daily/
vault/inbox/
vault/media/
vault/areas/
vault/archive/
